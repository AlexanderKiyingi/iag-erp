# Copy to .env for local dev
SERVICE_NAME=erp
PORT=4001
LOG_LEVEL=info
ENVIRONMENT=development
AUTO_MIGRATE=true
AUTH_MODE=jwt
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.erp
SERVICE_CLIENT_ID=iag-erp
SERVICE_CLIENT_SECRET=iag-erp-dev-secret-change-me
GATEWAY_API_PREFIX=/api/v1/erp
DATABASE_URL=postgres://svc_iag_erp:iag_erp_dev@localhost:5432/iag_platform?sslmode=disable
KAFKA_BROKERS=localhost:19092
KAFKA_OPERATIONS_TOPIC=iag.operations
KAFKA_CLIENT_ID=iag-erp
KAFKA_NOTIFICATIONS_TOPIC=iag.notifications
EVENT_BUS_ENABLED=true
HR_BIRTHDAY_DEPARTMENT_CODE=HR
# HR_BIRTHDAY_NOTIFY_EMAILS=hr-lead@iag.ug,people-ops@iag.ug
