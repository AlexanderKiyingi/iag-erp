SERVICE_NAME=erp
PORT=4001
ENVIRONMENT=production
AUTO_MIGRATE=false
AUTH_MODE=jwt
JWT_ISSUER=https://auth.example.com/api/v1/authentication
JWKS_URL=https://auth.example.com/api/v1/authentication/.well-known/jwks.json
AUDIENCE=iag.erp
SERVICE_CLIENT_ID=iag-erp
SERVICE_CLIENT_SECRET=
GATEWAY_API_PREFIX=/api/v1/erp
DATABASE_URL=postgres://svc_iag_erp:PASSWORD@HOST:5432/iag_platform?sslmode=require
KAFKA_BROKERS=kafka:9092
KAFKA_OPERATIONS_TOPIC=iag.operations
EVENT_BUS_ENABLED=true
